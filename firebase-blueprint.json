{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user account in Balanza Bikes",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The unique Firebase Authentication UID of the user"
        },
        "email": {
          "type": "string",
          "description": "User email address if registered via email/password or Google"
        },
        "displayName": {
          "type": "string",
          "description": "Name of the user"
        },
        "phoneNumber": {
          "type": "string",
          "description": "The verified phone number of the user if logging via phone OTP"
        },
        "notifyConsent": {
          "type": "boolean",
          "description": "Whether the user opted in to promotional updates"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp indicating when the account was created"
        }
      },
      "required": ["userId", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a bike purchase order",
      "type": "object",
      "properties": {
        "orderId": {
          "type": "string",
          "description": "The autogenerated or Firestore document ID of this order"
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who made the order"
        },
        "items": {
          "type": "array",
          "description": "List of cart items containing product information and quantities"
        },
        "itemsSubtotal": {
          "type": "number",
          "description": "Subtotal before discount"
        },
        "discountAmount": {
          "type": "number",
          "description": "Calculated promo code discount"
        },
        "finalTotal": {
          "type": "number",
          "description": "Grand total paid"
        },
        "status": {
          "type": "string",
          "enum": ["placed", "paid", "processing", "shipped", "delivered"],
          "description": "Order processing status"
        },
        "paymentMethod": {
          "type": "string",
          "description": "Optional payment method type selected"
        },
        "transactionId": {
          "type": "string",
          "description": "Transaction code or reference ID"
        },
        "detailsSummary": {
          "type": "string",
          "description": "A brief summary descriptor of the payment details used"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp from Firebase"
        }
      },
      "required": ["userId", "items", "itemsSubtotal", "finalTotal", "status", "createdAt"]
    },
    "NewsletterSubscription": {
      "title": "NewsletterSubscription",
      "description": "Represents email capture for updates and discount coupon triggers",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Captured subscriber email"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Email registration timestamp"
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Store registered user details"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Store secure transaction and bike purchase records"
    },
    "/newsletter_subscribers/{email}": {
      "schema": "NewsletterSubscription",
      "description": "Stores marketing subscribers for news or discount triggers"
    }
  }
}
